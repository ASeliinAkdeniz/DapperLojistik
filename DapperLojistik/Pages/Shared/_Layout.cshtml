<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DapperLojistik</title>

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

    <style>
        :root {
            --sidebar-width: 240px;
            --sidebar-bg: #1a1d2e;
            --topbar-height: 60px;
        }

        body {
            background: #f4f6fb;
            font-family: 'Segoe UI', sans-serif;
        }

        /* Sidebar */
        #sidebar {
            position: fixed;
            top: 0; left: 0; bottom: 0;
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            z-index: 1040;
            overflow-y: auto;
        }

        .sidebar-brand {
            padding: 1.2rem 1.5rem;
            border-bottom: 1px solid rgba(255,255,255,.07);
        }

        .brand-icon {
            width: 36px; height: 36px;
            background: #4361ee;
            border-radius: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .nav-section-title {
            font-size: .65rem;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: rgba(255,255,255,.3);
            padding: .8rem 1.5rem .3rem;
        }

        .sidebar-nav .nav-link {
            display: flex;
            align-items: center;
            gap: .75rem;
            padding: .6rem 1.5rem;
            color: #a0a8c0;
            font-size: .875rem;
            transition: background .15s, color .15s;
        }

        .sidebar-nav .nav-link:hover {
            background: rgba(255,255,255,.05);
            color: #fff;
        }

        .sidebar-nav .nav-link.active {
            background: rgba(67,97,238,.2);
            color: #fff;
            border-left: 3px solid #4361ee;
        }

        .sidebar-nav .nav-link i { font-size: 1.1rem; }

        /* Topbar */
        #topbar {
            position: fixed;
            top: 0; right: 0;
            left: var(--sidebar-width);
            height: var(--topbar-height);
            background: #fff;
            border-bottom: 1px solid #e8ecf0;
            z-index: 1030;
            display: flex;
            align-items: center;
            padding: 0 1.5rem;
        }

        /* İçerik Alanı */
        #main-content {
            margin-left: var(--sidebar-width);
            padding-top: calc(var(--topbar-height) + 1.5rem);
            padding-bottom: 2rem;
            padding-left: 1.5rem;
            padding-right: 1.5rem;
            min-height: 100vh;
        }

        /* Stat Kartları */
        .stat-icon {
            width: 52px; height: 52px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .bg-primary-soft  { background: rgba(67,97,238,.12); }
        .bg-success-soft  { background: rgba(25,135,84,.12); }
        .bg-warning-soft  { background: rgba(255,193,7,.12); }
        .bg-info-soft     { background: rgba(13,202,240,.12); }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <nav id="sidebar">
        <div class="sidebar-brand d-flex align-items-center gap-3">
            <div class="brand-icon">
                <i class="bi bi-truck text-white fs-5"></i>
            </div>
            <div>
                <div class="text-white fw-bold" style="font-size:.9rem">DapperLojistik</div>
                <div style="font-size:.7rem;color:rgba(255,255,255,.4)">Kargo Yönetim Sistemi</div>
            </div>
        </div>

        <ul class="sidebar-nav nav flex-column mt-2">
            <li class="nav-section-title">Yönetim</li>
            <li class="nav-item">
                <a href="/Dashboard" class="nav-link @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="bi bi-grid-fill"></i> Yönetici Dashboard
                </a>
            </li>
            <li class="nav-section-title mt-2">Operasyonlar</li>
            <li class="nav-item">
                <a href="/KargoListe" class="nav-link @(ViewData["ActivePage"]?.ToString() == "KargoListe" ? "active" : "")">
                    <i class="bi bi-table"></i> Kargo Listesi
                </a>
            </li>
            <li class="nav-item">
                <a href="/Operasyon" class="nav-link @(ViewData["ActivePage"]?.ToString() == "Operasyon" ? "active" : "")">
                    <i class="bi bi-plus-square-fill"></i> Yeni Kargo / CRUD
                </a>
            </li>
        </ul>
    </nav>

    <!-- Topbar -->
    <header id="topbar">
        <nav aria-label="breadcrumb" class="flex-fill">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item">
                    <a href="/Dashboard" class="text-decoration-none text-muted small">Ana Sayfa</a>
                </li>
                <li class="breadcrumb-item active small fw-semibold">@ViewData["Title"]</li>
            </ol>
        </nav>
        <div class="text-muted small">@DateTime.Now.ToString("dd MMM yyyy, HH:mm")</div>
    </header>

    <!-- İçerik -->
    <main id="main-content">
        @RenderBody()
    </main>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <!-- DataTables -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>